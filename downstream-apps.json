            "cat > target/downstream/logs/readstat/metadata.json <<'EOF'\n{\n  \"type\": \"SPSS\",\n  \"separator\": \";\",\n  \"variables\": [\n    {\"name\": \"name\", \"type\": \"STRING\", \"label\": \"Name\"},\n    {\"name\": \"score\", \"type\": \"NUMERIC\", \"label\": \"Score\", \"format\": \"NUMBER\", \"decimals\": 0},\n    {\"name\": \"notes\", \"type\": \"STRING\", \"label\": \"Notes\"}\n  ]\n}\nEOF"
          ],
