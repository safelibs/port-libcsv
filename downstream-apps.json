          ],
          "assert_steps": [
            "grep -q 'Converted 3 variables and 2 rows' target/downstream/logs/readstat/convert.log",
            "python3 - <<'PY'\nimport csv, json\nfrom pathlib import Path\nmeta = json.loads(Path('target/downstream/logs/readstat/extracted.json').read_text())\nassert [v['name'] for v in meta['variables']] == ['name', 'score', 'notes']\nwith Path('target/downstream/logs/readstat/roundtrip.csv').open(newline='', encoding='utf-8') as f:\n    rows = list(csv.reader(f))\nassert rows == [['name', 'score', 'notes'], ['Alice, A.', '42.000000', 'likes;semicolons'], ['Bob', '7.000000', 'plain text']]\nPY"
