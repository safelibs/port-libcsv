            "env LD_LIBRARY_PATH=target/downstream/install/readstat/usr/lib/x86_64-linux-gnu:target/downstream/install/readstat/usr/lib target/downstream/install/readstat/usr/bin/readstat target/downstream/logs/readstat/input.csv target/downstream/logs/readstat/metadata.json target/downstream/logs/readstat/output.dta > target/downstream/logs/readstat/convert.log 2>&1",
